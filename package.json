{
  "name": "portfolio-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "fmt": "prettier --write 'src/**/*.{ts,tsx,json,css}' 'app/**/*.{ts,tsx}'",
    "fmt:check": "prettier --check 'src/**/*.{ts,tsx,json,css}' 'app/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "check": "npm run fmt:check && npm run lint && npm run typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@emailjs/browser": "^4.4.1",
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/playfair-display": "^5.1.0",
    "@fontsource/roboto": "^5.1.0",
    "@fontsource/space-grotesk": "^5.2.10",
    "@mui/icons-material": "^5.14.18",
    "@mui/material": "^5.14.18",
    "@mui/material-nextjs": "^5.15.11",
    "@octokit/rest": "^21.1.0",
    "@phosphor-icons/react": "^2.1.10",
    "date-fns": "^4.1.0",
    "framer-motion": "^10.16.5",
    "gray-matter": "^4.0.3",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "sharp": "^0.33.5",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
